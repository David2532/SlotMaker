{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "baseUrl": ".",
    "paths": {
      "@slotmaker/config": ["packages/config/src/index.ts"],
      "@slotmaker/slot-runtime": ["packages/slot-runtime/src/index.ts"],
      "@slotmaker/math-engine": ["packages/math-engine/src/index.ts"],
      "@slotmaker/animation-system": ["packages/animation-system/src/index.ts"],
      "@slotmaker/sound-system": ["packages/sound-system/src/index.ts"],
      "@slotmaker/asset-pipeline": ["packages/asset-pipeline/src/index.ts"],
      "@slotmaker/validator": ["packages/validator/src/index.ts"],
      "@slotmaker/exporter": ["packages/exporter/src/index.ts"]
    }
  }
}
