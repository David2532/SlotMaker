{
  "name": "slotmaker",
  "version": "0.1.0",
  "private": true,
  "description": "SLOT FACTORY — a modular slot production platform. From idea to playable, math-tested, exportable slots.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r --filter \"./packages/*\" build",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "sim": "tsx scripts/simulate.ts",
    "validate": "tsx scripts/validate.ts",
    "export": "tsx scripts/export.ts",
    "editor": "pnpm --filter @slotmaker/editor dev",
    "editor:build": "pnpm --filter @slotmaker/editor build"
  },
  "devDependencies": {
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["esbuild"]
  }
}
